rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{document} {
      allow read, write: if true;
    }
    match /tasks/{document} {
      allow read, write: if true;
    }
    match /habits/{document} {
      allow read, write: if true;
    }
    match /feedback/{document} {
      allow read, write: if true;
    }
  }
}
